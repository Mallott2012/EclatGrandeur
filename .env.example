# ── Supabase ─────────────────────────────────────────────────────────────────
# Required for all authenticated / admin functionality.
# Get these from: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never expose in NEXT_PUBLIC_* variables or client code.
SUPABASE_SERVICE_ROLE_KEY=

# ── Transactional email ───────────────────────────────────────────────────────
# If unset, form submissions are logged to the server console instead of emailed.
RESEND_API_KEY=

# ── Payments (Phase 2 — not yet wired) ───────────────────────────────────────
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── Analytics (optional) ─────────────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=
