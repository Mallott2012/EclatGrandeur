# =============================================================================
# Supabase — required for the Phase 0 admin foundation (auth, roles, audit).
# =============================================================================
# Project URL and anon key are PUBLIC (safe in the browser; protected by RLS).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — SERVER ONLY. NEVER prefix with NEXT_PUBLIC_ and never import
# it into client components. Used only by server-only code (audit logging).
SUPABASE_SERVICE_ROLE_KEY=

# =============================================================================
# Storefront (existing) — optional.
# =============================================================================
# Transactional email for form submissions (enquiries & appointments).
# If unset, submissions are logged to the server console instead of emailed.
RESEND_API_KEY=

# Payments (Phase 2 — not yet wired)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Analytics (optional)
NEXT_PUBLIC_GA_ID=
