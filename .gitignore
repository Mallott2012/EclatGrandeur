# dependencies
/node_modules
/.pnp
.pnp.js

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store

# ── Credentials and private keys ─────────────────────────────────────────────
*.pem
*.key
*.p12
*.pfx

# ── Environment files ─────────────────────────────────────────────────────────
# .env.example is intentionally tracked (blank values only — no secrets).
# All other .env variants must remain local only.
.env
.env.*
.env*.local

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Backups and archives ──────────────────────────────────────────────────────
*.bak
*.backup
*.tar
*.tar.gz
*.zip

# ── Script output and temporary migration exports ────────────────────────────
# One-off migration/audit scripts must not commit their output.
scripts/*-result.json
scripts/*-data.json
scripts/old-*.json
scripts/tmp-*.json
scripts/*.export.json
scripts/*.log

# ── TypeScript ────────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Testing ───────────────────────────────────────────────────────────────────
/coverage

# ── Supabase CLI ──────────────────────────────────────────────────────────────
supabase/.temp/

# ── Vercel ────────────────────────────────────────────────────────────────────
.vercel
